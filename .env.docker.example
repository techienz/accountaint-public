# ─── Accountaint — Docker environment ──────────────────────────────────────
# Copy this file to `.env` next to docker-compose.yml, fill in the values,
# then run `docker compose up -d`.
#
# Generate secrets:
#   APP_ENCRYPTION_KEY   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   JWT_SECRET           node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   VAPID_*              npx web-push generate-vapid-keys

# ─── Required ──────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=
JWT_SECRET=
ANTHROPIC_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# ─── Local LLM (optional) ──────────────────────────────────────────────────
# LM Studio / Ollama runs on the host, not in the container.
# Use host.docker.internal to reach the host from inside Docker.
# (On Linux, this works on recent Docker versions; if not, use your host's LAN IP.)
#
# Alternatively, configure this in-app at Settings → Local LLM (values there
# override these env vars).
# LMSTUDIO_URL=http://host.docker.internal:1234/v1
# LMSTUDIO_CHAT_MODEL=qwen3.5-9b
# LMSTUDIO_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe

# ─── Xero (optional — only if you want parallel running with Xero) ─────────
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_GRANT_TYPE=client_credentials
# XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# ─── Akahu (optional — configure in-app via Settings → Bank Feeds instead) ─
# AKAHU_APP_TOKEN=
# AKAHU_APP_SECRET=
# AKAHU_REDIRECT_URI=http://localhost:3000/api/akahu/callback

# ─── Notes ─────────────────────────────────────────────────────────────────
# DATABASE_PATH is already set to /data/accountaint.db inside the container
# (mounted from ./data on the host). Don't override unless you know why.
