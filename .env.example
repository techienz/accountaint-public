# Required: 32-byte hex key for encrypting sensitive fields (IRD numbers, Xero tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Required: JWT signing secret (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional: Database file path (defaults to data/accountaint.db)
# DATABASE_PATH=

# Xero OAuth2 (required for Xero integration)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# For custom connections (pre-authorised to a single org), set:
XERO_GRANT_TYPE=client_credentials
# For web app OAuth2 flow (multiple orgs), set redirect URI instead:
# XERO_REDIRECT_URI=http://localhost:3020/api/xero/callback

# LM Studio (optional — falls back to Claude Haiku with PII sanitisation)
# LMSTUDIO_URL=http://localhost:1234/v1
# LMSTUDIO_CHAT_MODEL=qwen3.5-9b
# LMSTUDIO_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe

# Web Push VAPID keys (required for desktop notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Akahu Open Banking (optional — for NZ bank feed sync)
# AKAHU_APP_TOKEN=
# AKAHU_APP_SECRET=
# AKAHU_REDIRECT_URI=http://localhost:3020/api/akahu/callback

# Claude API (required for AI chat)
ANTHROPIC_API_KEY=
